{
  "name": "@jellyrock/shared-ui",
  "version": "1.0.0",
  "private": true,
  "description": "Shared header, footer, tokens, and nav data for all JellyRock websites.",
  "license": "MIT",
  "author": "Charles Ewert",
  "homepage": "https://github.com/jellyrock/shared-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jellyrock/shared-ui.git"
  },
  "bugs": {
    "url": "https://github.com/jellyrock/shared-ui/issues"
  },
  "type": "module",
  "scripts": {
    "check": "npm run check:tsc && npm run check:eslint && npm run check:prettier",
    "check:tsc": "tsc --noEmit",
    "check:eslint": "eslint .",
    "check:prettier": "prettier --check .",
    "fix": "eslint --fix . && prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@typescript-eslint/parser": "^8.39.0",
    "astro-eslint-parser": "^1.2.2",
    "eslint": "^9.33.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.0"
  }
}
